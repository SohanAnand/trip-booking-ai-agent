# Trip Booking Concierge — environment template
# Copy to .env and fill in values. Never commit .env.

# --- LLM ---
# Leave ANTHROPIC_API_KEY empty + set MOCK_LLM=1 to run the demo offline.
ANTHROPIC_API_KEY=
MOCK_LLM=1
LLM_MODEL_PRIMARY=claude-sonnet-4-6
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# --- Backend ---
BACKEND=sqlite
SQLITE_PATH=./data/trip.db

# --- Approval signing keys (Ed25519, base64url) ---
# Generate via: python -c "from approval.tokens import generate_keypair; generate_keypair()"
APPROVAL_SIGNING_KEY=
APPROVAL_VERIFY_KEY=
APPROVAL_KID=v1

# --- Budget ceilings ---
REQUEST_MAX_DOLLARS=5.00
REQUEST_MAX_SECONDS=300

# --- M2: real APIs (leave blank for M1) ---
# Duffel (preferred) — get a test token at https://app.duffel.com → Developers
DUFFEL_ACCESS_TOKEN=
DUFFEL_API_VERSION=v2
# Duffel Stays is gated. Free test tokens get 403 on /stays/search.
# Set to true ONLY after Duffel sales has enabled Stays on your account.
DUFFEL_STAYS_ENABLED=false
# LiteAPI (preferred for hotels) — self-serve signup at https://www.liteapi.travel/
LITEAPI_KEY=
LITEAPI_USE_SANDBOX=true
# Amadeus (alternative)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
OPENWEATHER_API_KEY=
VOYAGE_API_KEY=

# --- M5: payment (Stripe TEST mode only) ---
STRIPE_TEST_KEY=
BOOKING_PROVIDER=mock_always

# --- Demo user (M1) ---
DEMO_USER_ID=demo-user-001
DEMO_USER_PHONE=+15555550100
